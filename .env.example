# Arcane Peptides — Environment Variables
# Copy to .env.local and fill in values before running locally or deploying.

# ── Site ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://arcanepeptides.co.uk

# ── Firebase (accounts / sign-in) ─────────────────────────────────────────
# From Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY="TODO: your Firebase API key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="TODO: yourproject.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="TODO: yourproject"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="TODO: yourproject.firebasestorage.app"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="TODO: sender id"
NEXT_PUBLIC_FIREBASE_APP_ID="TODO: app id"

# App Check — reCAPTCHA v3 SITE key (public). Required if App Check is enforced.
# The matching SECRET key goes in the Firebase console, not here.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="TODO: reCAPTCHA v3 site key"

# ── Admin / CRM ──────────────────────────────────────────────────────────
# Comma-separated emails granted access to the /admin CRM dashboard.
# Defaults to leogray15@gmail.com. MUST match the email(s) in firestore.rules.
# NEXT_PUBLIC_ADMIN_EMAILS="leogray15@gmail.com"

# ── Payment — Bank Transfer ──────────────────────────────────────────────
# Bank details shown on the order-confirmation page (never commit real values)
NEXT_PUBLIC_BANK_NAME="TODO: Your Bank Name"
NEXT_PUBLIC_BANK_SORT_CODE="TODO: 00-00-00"
NEXT_PUBLIC_BANK_ACCOUNT_NUMBER="TODO: 00000000"
NEXT_PUBLIC_BANK_ACCOUNT_NAME="TODO: Account Name"
NEXT_PUBLIC_BANK_IBAN="TODO: GB00XXXX"

# ── Payment — Crypto ─────────────────────────────────────────────────────
# Wallet addresses shown at checkout
NEXT_PUBLIC_CRYPTO_BTC_ADDRESS="TODO: bc1q..."
NEXT_PUBLIC_CRYPTO_ETH_ADDRESS="TODO: 0x..."
NEXT_PUBLIC_CRYPTO_USDT_TRC20="TODO: T..."

# ── Notifications ────────────────────────────────────────────────────────
# Where new orders land (server-side email; not exposed to client)
ORDER_NOTIFY_EMAIL=orders@arcanepeptides.co.uk

# ── WhatsApp ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER="TODO: +44..."

# ── Analytics (optional) ─────────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
