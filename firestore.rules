rules_version = '2';

// Arcane Peptides — Firestore security rules (hardened)
// Admins are matched by allow-listed email on the auth token. Keep this in
// sync with lib/config.ts (ADMIN_EMAILS).
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() in ['leogray15@gmail.com'];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Customer / account profiles ──
    match /users/{userId} {
      allow read:           if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete:         if isAdmin();
    }

    // ── Orders ──
    match /orders/{orderId} {
      // A customer reads only their own orders; admins read all.
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);

      // A customer may only create their own order, starting as pending payment.
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending_payment'
        && request.resource.data.totalGBP is number;

      // Only admins can change status / tracking / notes, or delete.
      allow update, delete: if isAdmin();
    }

    // ── Site settings (bank / crypto details shown at checkout) ──
    match /settings/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Everything else: denied ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
